# ─── Postgres (local dev via docker-compose) ────────────────────────────────
POSTGRES_DB=notes
POSTGRES_USER=notes
POSTGRES_PASSWORD=notes
DATABASE_URL=postgres://notes:notes@localhost:5432/notes

# ─── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── AWS Cognito ─────────────────────────────────────────────────────────────
# After running: terraform -chdir=infra apply
# Fill in these values from: terraform -chdir=infra output
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=notes-dev.auth.us-east-1.amazoncognito.com
# Derived (do not change format):
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
COGNITO_JWKS_URI=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Internal backend URL (for server-side Next.js Route Handlers)
BACKEND_INTERNAL_URL=http://localhost:8000
# Cookie security (set to "false" for local HTTP, "true" when behind HTTPS)
COOKIE_SECURE=false

# ─── AWS (only needed for scripts/deploy.sh) ────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ENV=dev
